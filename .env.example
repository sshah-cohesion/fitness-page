# Apple Wallet Pass signing (required for real .pkpass downloads)
# Create a Pass Type ID + certificates in Apple Developer, then base64-encode the PEM files:
#   base64 -i wwdr.pem | tr -d '\n'
#   base64 -i signerCert.pem | tr -d '\n'
#   base64 -i signerKey.pem | tr -d '\n'
#
# Set these in the Vercel project → Settings → Environment Variables

APPLE_PASS_TYPE_ID=pass.com.yourcompany.fitness
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_WWDR_BASE64=
APPLE_SIGNER_CERT_BASE64=
APPLE_SIGNER_KEY_BASE64=
APPLE_SIGNER_KEY_PASSPHRASE=
